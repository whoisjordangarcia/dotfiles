#background-opacity = 0.90
clipboard-read = allow
clipboard-write = allow

confirm-close-surface = false

#font-family = CozetteVector
#font-family = JetBrainsMono Nerd Font
#font-family = JetBrainsMono Nerd Font Mono
#font-family = Terminess Nerd Font Mono
font-family = GohuFont 14 Nerd Font Mono
font-size = 16

# Platform-specific overrides (only loaded if file exists)
config-file = ?platform-linux
config-file = ?platform-macos
macos-titlebar-style = hidden
mouse-hide-while-typing = true

theme = dark:Catppuccin Mocha,light:Catppuccin Frappe
unfocused-split-opacity = 0.9

window-decoration = false
window-padding-x = 5
window-padding-y = 14,0
window-padding-balance = false
window-padding-color = extend
confirm-close-surface = false
resize-overlay = never

cursor-style = "block"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# no-cursor: prevent shell integration from overriding cursor-style settings above
# ssh-env: auto-send TERM/TERMINFO to remote hosts so ghostty terminfo works over SSH
shell-integration-features = no-cursor,ssh-env

shell-integration = zsh
term = ghostty

# Fix general slowness on Hyprland
async-backend = epoll  

