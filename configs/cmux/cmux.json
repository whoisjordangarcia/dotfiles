{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  // --- Pane focus: vim home-row, ported from vim-tmux-navigator ---
  // cmux can't do the plugin's "only-navigate-outside-vim" trick, and bare ctrl+h/j/k/l
  // would clobber readline/vim inside the pane, so we use cmd+opt+<hjkl> (a safe namespace).
  // This REPLACES the default opt+cmd+arrow focus bindings.
  "shortcuts": {
    "bindings": {
      // Pane focus: vim home-row (⌥⌘ = Cmd-based, intercepted by the app — works inside TUIs).
      "focusLeft": "cmd+opt+h",
      "focusDown": "cmd+opt+j",
      "focusUp": "cmd+opt+k",
      "focusRight": "cmd+opt+l",

      // Split bindings removed — ctrl+a is reserved for tmux prefix.
    }
  },

  // --- App behavior ---
  // New workspaces inherit the parent's working directory. This is the cmux
  // DEFAULT (true), set explicitly here to document intent: spawning a workspace
  // from inside a worktree keeps you in that worktree's cwd instead of jumping to
  // a default root. (Tab-level cwd inheritance via Cmd+T is native and needs no flag.)
  "app": {
    "workspaceInheritWorkingDirectory": true
  },

  // --- Native replacements for tmux statusline/resurrect machinery ---
  "terminal": {
    "autoResumeAgentSessions": true,
    // Select-to-copy (tmux muscle memory). Replaces the commented-out tmux
    // copy-pipe-and-cancel binding — selecting text copies it to the clipboard.
    "copyOnSelect": true
  },
  "automation": {
    "claudeCodeIntegration": true,
    "suppressSubagentNotifications": true
  }
}
