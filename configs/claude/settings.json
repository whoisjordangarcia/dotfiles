{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(gh api *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh run view *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git pull *)",
      "Bash(git rm *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(docker build *)",
      "Bash(npm info *)",
      "Bash(npm run *)",
      "Bash(npx eslint *)",
      "Bash(npx tsc *)",
      "Bash(nx *)",
      "Bash(pnpm *)",
      "Bash(task *)",
      "Bash(wt *)",
      "Skill(superpowers:brainstorming)",
      "Skill(superpowers:writing-plans)",
      "mcp__pencil"
    ],
    "deny": [
      "Read(./**/*.htpasswd)",
      "Read(./**/*.jks)",
      "Read(./**/*.key)",
      "Read(./**/*.keystore)",
      "Read(./**/*.netrc)",
      "Read(./**/*.npmrc)",
      "Read(./**/*.p12)",
      "Read(./**/*.pem)",
      "Read(./**/*.pfx)",
      "Read(./**/*.pgpass)",
      "Read(./**/*.pypirc)",
      "Read(./**/*.tfstate)",
      "Read(./**/*.tfvars)",
      "Read(./**/*credentials*)",
      "Read(./**/*id_ed25519*)",
      "Read(./**/*id_rsa*)",
      "Read(./**/*password*)",
      "Read(./**/*secret*)",
      "Read(./**/kubeconfig)",
      "Read(./**/serviceAccountKey*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.envrc)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.config/nest-skills/*)",
      "Read(~/.docker/config.json)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/config)",
      "Read(~/.ssh/**)",
      "Read(~/.zshrc-modules/.zshrc.sec)",
      "Read(~/.zshrc-sec)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(curl *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "code-review@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "dev-browser@dev-browser-marketplace": false,
    "explanatory-output-style@claude-plugins-official": true,
    "nest-ai-skill-audit@nest-genomics-skills": true,
    "nest-linear@nest-genomics-skills": true,
    "nest-portal-sign-in@nest-genomics-skills": true,
    "nest-posthog@nest-genomics-skills": true,
    "nest-pr@nest-genomics-skills": true,
    "nest-preview-branch@nest-genomics-skills": true,
    "nest-preview-cleanup@nest-genomics-skills": true,
    "nest-release-stg@nest-genomics-skills": true,
    "nest-release-summary@nest-genomics-skills": true,
    "nest-retool-json-schema-forms@nest-genomics-skills": true,
    "nest-sentry@nest-genomics-skills": true,
    "nest-slite@nest-genomics-skills": true,
    "playwright-skill@playwright-skill": false,
    "superpowers@superpowers-marketplace": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "impeccable@impeccable": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    }
  },
  "outputStyle": "Explanatory",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "git"
    ]
  },
  "spinnerTipsEnabled": true,
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Nesting",
      "sahh good",
      "ralphing"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    }
  },
  "skipAutoPermissionPrompt": true
}
