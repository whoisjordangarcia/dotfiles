# Extract various archives
extract() {
    if [[ -f "$1" ]]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"    ;;
            *.tar.gz)    tar xzf "$1"    ;;
            *.tar.xz)    tar xJf "$1"    ;;
            *.bz2)       bunzip2 "$1"    ;;
            *.rar)       unrar x "$1"    ;;
            *.gz)        gunzip "$1"     ;;
            *.tar)       tar xf "$1"     ;;
            *.tbz2)      tar xjf "$1"    ;;
            *.tgz)       tar xzf "$1"    ;;
            *.zip)       unzip "$1"      ;;
            *.Z)         uncompress "$1" ;;
            *.7z)        7z x "$1"       ;;
            *.deb)       ar x "$1"       ;;
            *.tar.zst)   tar --zstd -xf "$1" ;;
            *)           echo "\$1 cannot be extracted via extract()" ;;
        esac
    else
        echo "\$1 is not a valid file"
    fi
}

# Create compressed archives
mktar() { tar czf "\${1}.tar.gz" "\${1}"; }
mktbz() { tar cjf "\${1}.tar.bz2" "\${1}"; }
mkzip() { zip -r "\${1}.zip" "\${1}"; }

