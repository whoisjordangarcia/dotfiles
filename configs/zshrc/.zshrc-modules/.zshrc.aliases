alias reload="source ~/.zshrc"
alias ls="eza --icons"
alias cat="bat"
alias top="btop"
alias preview='fzf --preview="bat {} --color=always"'
alias wm='workmux'

#arch 
alias hyprc="nvim ~/.config/hypr/hyprland.conf"

#development
alias c="CLAUDE_CODE_NO_FLICKER=1 claude"
alias cr="=CLAUDE_CODE_NO_FLICKER=1 claude --resume"
alias claude-yolo="CLAUDE_CODE_NO_FLICKER=1 claude --dangerously-skip-permissions"
#alias cy="CLAUDE_CODE_NO_FLICKER=1 claude --dangerously-skip-permissions"
alias ca="CLAUDE_CODE_NO_FLICKER=1 claude --enable-auto-mode"
alias update-claude="curl -fsSL https://claude.ai/install.sh | bash"
alias lg="lazygit"
alias vim="nvim"
alias vi="nvim"
alias vimrc="nvim ~/.config/nvim/init.lua"
alias nvim-kickstart='NVIM_APPNAME="nvim-starter" nvim'
alias nvchad='NVIM_APPNAME="nvchad" nvim'
alias avante='nvim -c "lua vim.defer_fn(function()require(\"avante.api\").zen_mode()end, 100)"'
alias reqrepo-env='~/.zshrc-modules/scripts/activate-reqrepo-env'

#firewall
alias fw="sudo ufw status verbose"
alias fw-allow="sudo ufw allow"
alias fw-deny="sudo ufw deny"
alias fw-reload="sudo ufw reload"

#vpn
alias vpn-up="bash ~/.config/vpn-split/vpn-up.sh"
alias vpn-down="bash ~/.config/vpn-split/vpn-down.sh"
alias vpn-gen-config="bash ~/.config/vpn-split/vpn-gen-config.sh"
alias vpn-status="nmcli connection show --active | grep vpn"
alias vpn-exclude="$EDITOR ~/.config/vpn-split/exclude-domains.txt"

alias :q="exit"
alias :wq="exit"
alias :x="exit"
alias zshrc="nvim ~/.zshrc-modules"
alias dotfiles="cd ~/dev/dotfiles && nvim ."
alias sketchybar-theme="~/.config/sketchybar/switch-theme.sh"

#git
alias gs="git status"
alias gd="git diff"
alias gcm="git checkout main"
alias gpo="git pull origin"
alias gc='git checkout'
alias grm="git pull --rebase origin main"
alias gpf="git push --force-with-lease"
