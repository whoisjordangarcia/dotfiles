+    /// Drain pending mpv events; return the reason if the file ended.
+    /// Event-driven end detection: unlike polling idle-active, an EndFile
+    /// event can't be confused with "network stream still opening", and the
+    /// reason distinguishes eof / replaced-by-loadfile / stream error.
+    pub fn poll_ended(&mut self) -> Option<libmpv2::EndFileReason> {
+        let mut ended = None;
+        while let Some(ev) = self.mpv.event_context_mut().wait_event(0.0) {
+            match ev {
+                Ok(e) => {
+                    tracing::info!("mpv event: {:?}", e);
+                    if let libmpv2::events::Event::EndFile(reason) = e {
+                        ended = Some(reason);
+                    }
+                }
+                Err(e) => tracing::info!("mpv event error: {:?}", e),
+            }
+        }
+        ended
+    }
+
     pub fn is_idle(&self) -> bool {
         self.mpv.get_property("idle-active").unwrap_or(true)
     }
