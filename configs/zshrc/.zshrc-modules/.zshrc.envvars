export LANG=en_US.UTF-8

if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nvim'
fi
# Some tools (git, kubectl, crontab) prefer $VISUAL for full-screen editors.
export VISUAL="$EDITOR"

# NVM_DIR is set in .zshrc.init (lightweight node manager)
# Full nvm is available via: source "$HOME/.nvm/nvm.sh"
export PYENV_ROOT="$HOME/.pyenv"

# ==============================================================================
#  Colored Man Pages (using bat)
# ==============================================================================

# Use bat as man pager for beautiful syntax highlighting
# Force paging=always to override bat config's --paging=never
export MANPAGER="sh -c 'col -bx | bat -l man --paging=always'"
export MANROFFOPT="-c"

# ==============================================================================
#  Homebrew
# ==============================================================================

export HOMEBREW_NO_ENV_HINTS=1
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_BAT=1
export HOMEBREW_AUTOREMOVE=1

# ==============================================================================
#  Telemetry / Privacy opt-out
# ==============================================================================

# Cross-tool standard honored by gh, bat, direnv, and many others.
# See https://consoledonottrack.com
export DO_NOT_TRACK=true

# ==============================================================================
#  Terminal hyperlinks (OSC 8)
# ==============================================================================

# Ghostty fully supports OSC 8 clickable links, but tools like Claude Code only
# emit them for an allowlist of auto-detected terminals (iTerm2, Kitty, WezTerm).
# Ghostty isn't on that list, so force it on — makes statusline PR links etc.
# Cmd+clickable. Harmless on terminals that already support hyperlinks.
export FORCE_HYPERLINK=1

# export AGENT_BROWSER_PROVIDER=ios
# export AGENT_BROWSER_IOS_DEVICE="iPhone 16 Pro"
