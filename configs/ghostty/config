# Glass mode: slight translucency + native blur (macOS; Hyprland blurs via compositor)
background-opacity = 0.9
background-blur = 20
clipboard-read = allow
clipboard-write = allow

confirm-close-surface = false

#font-family = CozetteVector
#font-family = JetBrainsMono Nerd Font
#font-family = JetBrainsMono Nerd Font Mono
#font-family = Terminess Nerd Font Mono
font-family = GohuFont 14 Nerd Font Mono
font-size = 16

# Platform-specific overrides (only loaded if file exists)
config-file = ?platform-linux
config-file = ?platform-macos
macos-titlebar-style = hidden
mouse-hide-while-typing = true

#theme = dark:Catppuccin Mocha,light:Catppuccin Frappe
# dark:/light: auto-switches with the system color-scheme reported over the
# XDG portal (org.freedesktop.appearance). On Hyprland this requires the gtk
# portal backend to be unmasked so it can serve the Settings interface.
theme = dark:Rose Pine,light:Rose Pine Dawn
unfocused-split-opacity = 0.9

# Faint wallpaper behind the terminal (repo clones to ~/dev/dotfiles on every box).
# Disabled: the 0.15 overlay reads as a translucent/washed-out background.
# Re-enable these four lines to bring the faint wallpaper back.
#background-image = ~/dev/dotfiles/wallpapers/desktop.jpg
#background-image-opacity = 0.15
#background-image-fit = cover
#background-image-position = center

window-decoration = false
window-padding-x = 5
window-padding-y = 14,0
window-padding-balance = false
window-padding-color = extend
confirm-close-surface = false
resize-overlay = never

cursor-style = "block"
cursor-style-blink = false

macos-non-native-fullscreen = true

# Cursor styling + SSH session terminfo
# no-cursor: prevent shell integration from overriding cursor-style settings above
# ssh-env: auto-send TERM/TERMINFO to remote hosts so ghostty terminfo works over SSH
shell-integration-features = no-cursor,ssh-env

shell-integration = zsh
term = ghostty

# Fix general slowness on Hyprland
async-backend = epoll  

