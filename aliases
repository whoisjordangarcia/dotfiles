# Kill process by port
killport() {
    local port="$1"
    local pid=$(lsof -t -i:"$port" 2>/dev/null || ss -tlnp | grep ":$port " | awk '{print $7}' | cut -d',' -f2 | cut -d'=' -f2 | head -1)
    if [[ -n "$pid" ]]; then
        echo "Killing process $pid on port $port"
        kill -9 "$pid" 2>/dev/null || sudo kill -9 "$pid"
    else
        echo "No process found on port $port"
    fi
}

# Quick HTTP server
