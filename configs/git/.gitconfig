[user]
	name = Jordan Garcia
	email = arickho@gmail.com

[init]
  defaultBranch = main

[core]
  editor = nvim
  autocrlf = input
  safecrlf = true
  filemode = false 
	pager = bat
  excludesfile = ~/.gitignore_global

[color]
  ui = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold

[color "status"]
    added = green
    changed = yellow
    untracked = red

[push]
  default = current
  autoSetupRemote = true

[pull]
  rebase = true

[fetch]
  prune = true

[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true

[commit]
  verbose = true

[column]
  ui = auto

[branch]
  sort = -committerdate

[tag]
  sort = -version:refname

[rerere]
  enabled = true
  autoupdate = true

[includeIf "gitdir:~/projects/work/"]
  path = ~/projects/work/.gitconfig

